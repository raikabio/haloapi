{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    
    /* Modern, clean import path resolution */
    "module": "ESNext",
    "moduleResolution": "Bundler", 
    "esModuleInterop": true,
    "isolatedModules": true,
    
    /* Strictness & Safety */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Output Handling */
    "outDir": "./dist",
    "rootDir": "./api",
    "removeComments": true
  },
  "include": ["api/**/*"],
  "exclude": ["node_modules", "dist"]
}